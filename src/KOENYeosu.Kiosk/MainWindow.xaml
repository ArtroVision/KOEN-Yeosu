<Window x:Class="KOENYeosu.Kiosk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KOEN Yeosu SMART LOTO"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#07111F"
        Width="1080" Height="1920">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="160" />
            <RowDefinition Height="*" />
            <RowDefinition Height="120" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0B1E35" Padding="48,32">
            <DockPanel LastChildFill="True">
                <StackPanel>
                    <TextBlock Text="한국남동발전 여수발전본부" Foreground="#D8F1FF" FontSize="34" FontWeight="SemiBold" />
                    <TextBlock Text="SMART LOTO System" Foreground="#71D8FF" FontSize="24" Margin="0,8,0,0" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="Kiosk" Foreground="#9FE6FF" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="72">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="안전한 작업을 위한" Foreground="#9FB7CA" FontSize="34" HorizontalAlignment="Center" />
                <TextBlock Text="Smart LOTO" Foreground="White" FontSize="92" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,18,0,8" />
                <TextBlock Text="에너지 격리 잠금장치 관리 시스템" Foreground="#BFD6E6" FontSize="30" HorizontalAlignment="Center" />

                <UniformGrid Columns="1" Rows="3" Margin="0,120,0,0">
                    <Button Content="키 반출  |  Key Checkout" FontSize="38" Height="150" Margin="0,0,0,28" />
                    <Button Content="키 반납  |  Key Return" FontSize="38" Height="150" Margin="0,0,0,28" />
                    <Button Content="현황 보기  |  Key Status" FontSize="38" Height="150" />
                </UniformGrid>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="#081728" Padding="48,24">
            <DockPanel>
                <TextBlock Text="Device ID  YS-L-045-K" Foreground="#AFC3D3" FontSize="24" VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Right" Text="네트워크 정상" Foreground="#5EF2A0" FontSize="24" HorizontalAlignment="Right" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
